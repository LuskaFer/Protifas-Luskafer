            <p className="col-start-2 text-sm text-destructive">{errors.title.message}</p>
          )}
        </div>
        <div className="grid grid-cols-[130px_1fr] items-center gap-4">
          <Label htmlFor="exp-company">Empresa</Label>
          <Input id="exp-company" {...register('company')} placeholder="Nome da empresa" />
          {errors.company && (
            <p className="col-start-2 text-sm text-destructive">{errors.company.message}</p>
          )}
        </div>
        <div className="grid grid-cols-[130px_1fr] items-center gap-4">
          <Label htmlFor="exp-period">Período</Label>
          <Input
            id="exp-period"
            {...register('period')}
            placeholder="Ex: Jan 2023 — Dez 2024"
          />
          {errors.period && (
            <p className="col-start-2 text-sm text-destructive">{errors.period.message}</p>
          )}
        </div>
        <div className="grid grid-cols-[130px_1fr] items-start gap-4">
          <Label className="pt-2" htmlFor="exp-description">
            Descrição
          </Label>
          <textarea
            id="exp-description"
            {...register('description')}
            className="w-full resize-none rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-xs placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
            placeholder="Descrição da experiência (markdown suportado)..."
            rows={8}
          />
          {errors.description && (
            <p className="col-start-2 text-sm text-destructive">{errors.description.message}</p>
          )}
        </div>
      </section>
    </div>
  )
}
